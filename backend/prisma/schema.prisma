generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  customer
  admin
  support
}

enum WalletTransactionType {
  deposit
  charge
  refund
  adjustment
}

enum PaymentProvider {
  stripe
}

enum PaymentStatus {
  pending
  succeeded
  failed
  canceled
}

enum OrderStatus {
  pending
  queued
  processing
  completed
  partial
  canceled
  failed
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  fullName         String?
  passwordHash     String?
  refreshTokenHash String?
  provider         String   @default("email")
  role             UserRole @default(customer)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  wallet Wallet?
  orders Order[]
  adminActionLogs AdminActionLog[]
}

model Wallet {
  id            String              @id @default(cuid())
  userId        String              @unique
  balance       Decimal             @default(0) @db.Decimal(12, 2)
  currency      String              @default("USD")
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  WalletTransaction[]
  payments      Payment[]
}

model Platform {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  icon        String?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  categories  Category[]
  services    Service[]

  @@index([isActive, sortOrder])
}

model Category {
  id          String    @id @default(cuid())
  platformId  String
  name        String
  slug        String
  description String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  platform    Platform  @relation(fields: [platformId], references: [id], onDelete: Cascade)
  services    Service[]

  @@unique([platformId, slug])
  @@index([platformId, isActive, sortOrder])
}

model Service {
  id            String    @id @default(cuid())
  platformId    String
  categoryId    String
  name          String
  slug          String    @unique
  providerServiceId String?
  description   String
  shortDescription String?
  pricePerK     Decimal   @db.Decimal(12, 2)
  minOrder      Int
  maxOrder      Int
  deliverySpeed String?
  guarantee     String?
  refillPolicy  String?
  isFeatured    Boolean   @default(false)
  isActive      Boolean   @default(true)
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  platform      Platform  @relation(fields: [platformId], references: [id], onDelete: Restrict)
  category      Category  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  orders        Order[]

  @@index([platformId, categoryId, isActive, sortOrder])
  @@index([isFeatured, isActive, sortOrder])
}

model WalletTransaction {
  id            String                @id @default(cuid())
  walletId      String
  providerRef   String?
  reference     String?
  amount        Decimal               @db.Decimal(12, 2)
  balanceBefore Decimal               @db.Decimal(12, 2)
  balanceAfter  Decimal               @db.Decimal(12, 2)
  currency      String                @default("USD")
  type          WalletTransactionType
  description   String?
  metadata      Json?
  status        String                @default("completed")
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
  @@index([type, createdAt])
}

model Payment {
  id                String          @id @default(cuid())
  walletId          String
  provider          PaymentProvider @default(stripe)
  status            PaymentStatus   @default(pending)
  amount            Decimal         @db.Decimal(12, 2)
  currency          String          @default("USD")
  checkoutSessionId String          @unique
  paymentIntentId   String?         @unique
  providerRef       String?
  description       String?
  metadata          Json?
  creditedAt        DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  wallet            Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
  @@index([status, createdAt])
}

model Order {
  id                String           @id @default(cuid())
  userId            String
  serviceId         String
  quantity          Int
  chargeAmount      Decimal          @db.Decimal(12, 2)
  currency          String           @default("USD")
  targetUrl         String
  status            OrderStatus      @default(pending)
  providerServiceId String?
  providerOrderId   String?          @unique
  startCount        Int?
  remains           Int?
  notes             String?
  canceledAt        DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  service           Service          @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  statusLogs        OrderStatusLog[]

  @@index([userId, createdAt])
  @@index([serviceId, createdAt])
  @@index([status, createdAt])
}

model OrderStatusLog {
  id          String      @id @default(cuid())
  orderId     String
  status      OrderStatus
  message     String?
  metadata    Json?
  createdAt   DateTime    @default(now())

  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

model QueueJobLog {
  id         String   @id @default(cuid())
  queueName  String
  jobName    String
  status     String
  payload    Json?
  createdAt  DateTime @default(now())
}

model AdminActionLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  actor      User     @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId, createdAt])
  @@index([entityType, createdAt])
}
