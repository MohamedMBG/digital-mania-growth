NODE_ENV=development
PORT=4000
API_PREFIX=api
FRONTEND_URL=http://localhost:8080

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/nexora?schema=public

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0

JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

STRIPE_SECRET_KEY=sk_test_change_me
STRIPE_WEBHOOK_SECRET=whsec_change_me
STRIPE_CURRENCY=usd
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:8080/wallet/success
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:8080/wallet/cancel

PROVIDER_URL=https://example-provider.com/api/v2
PROVIDER_API_KEY=replace-with-provider-api-key

LOG_LEVEL=debug
BULLMQ_PREFIX=nexora
CACHE_TTL_SECONDS=120
